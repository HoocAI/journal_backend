generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  googleId            String?            @unique
  passwordHash        String
  role                Role               @default(USER)
  plan                Plan               @default(TRIAL)
  trialEndsAt         DateTime?
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  age                 Int?
  focus               String[]
  language            String?
  name                String?
  timezone            String?
  gender              String?
  phone               String?            @unique
  goalsSet            Boolean            @default(false)
  onboardingCompleted Boolean            @default(false)
  isEmailVerified     Boolean            @default(false)
  isPhoneVerified     Boolean            @default(false)
  coins               Int                @default(0)
  currentStreak       Int                @default(0)
  lastEntryDate       DateTime?
  longestStreak       Int                @default(0)
  fcmToken            String?
  photoUrl            String?
  photoS3Key          String?
  AssessmentResult    AssessmentResult[]
  consent             Consent?
  goals               Goal[]
  journalEntries      JournalEntry[]
  moods               MoodEntry[]
  answers             QuestionAnswer[]
  sessions            Session[]
  visionBoards        VisionBoard[]
  dailyPhotos         DailyPhoto[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Consent {
  id                String   @id @default(uuid())
  userId            String   @unique
  termsAccepted     Boolean
  privacyAccepted   Boolean
  recordingAccepted Boolean  @default(false)
  acceptedAt        DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id        String   @id @default(uuid())
  userId    String
  content   String
  photoUrl    String?
  photoS3Key  String?
  audioUrl    String?
  audioS3Key  String?
  entryDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryDate])
}

model MoodEntry {
  id          String   @id @default(uuid())
  userId      String
  mood        MoodType
  reason      String?
  entryDate   DateTime
  createdAt   DateTime @default(now())
  whySuchMood String?
  whyThisMood String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, entryDate])
}

model Goal {
  id          String    @id @default(uuid())
  userId      String
  type        String
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deadline    DateTime?
  isAutomated Boolean   @default(false)
  targetValue String?
  templateKey String?
  affirmation String?
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  AssessmentResult AssessmentResult[]

  @@index([userId])
  @@index([userId, type])
}

model QuestionSet {
  id        String     @id @default(uuid())
  title     String
  startDate DateTime
  createdAt DateTime   @default(now())
  questions Question[]
}

model Question {
  id            String           @id @default(uuid())
  questionSetId String
  text          String
  order         Int
  questionSet   QuestionSet      @relation(fields: [questionSetId], references: [id])
  answers       QuestionAnswer[]

  @@unique([questionSetId, order])
}

model QuestionAnswer {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  answer     String
  createdAt  DateTime @default(now())
  answerDate DateTime
  question   Question @relation(fields: [questionId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, answerDate])
}

model AdminAudio {
  id        String   @id @default(uuid())
  title     String
  audioUrl  String
  s3Key     String?
  createdAt DateTime @default(now())
}

model Quote {
  id        String   @id @default(uuid())
  text      String
  author    String?
  mood      MoodType
  createdAt DateTime @default(now())
}

model Affirmation {
  id        String   @id @default(uuid())
  text      String
  author    String?
  mood      MoodType
  createdAt DateTime @default(now())
}

model VisionBoard {
  id        String             @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  sections        Json?
  selectedGoalIds String[]           @default([])
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  images          VisionBoardImage[]

  @@unique([userId, name])
  @@index([userId])
}

model VisionBoardImage {
  id            String      @id @default(uuid())
  visionBoardId String
  url           String
  s3Key         String
  createdAt     DateTime    @default(now())
  board         VisionBoard @relation(fields: [visionBoardId], references: [id], onDelete: Cascade)

  @@index([visionBoardId])
}

model AssessmentResult {
  id              String   @id @default(uuid())
  userId          String
  goalId          String
  type            String
  finalScore      Float
  dimensionScores Json
  customerLevel   String?
  adminLevel      String?
  createdAt       DateTime @default(now())
  User            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Goal            Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([goalId])
}

model DailyPhoto {
  id        String   @id @default(uuid())
  userId    String
  url       String
  s3Key     String
  date      DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model BreathingPattern {
  id        String   @id
  mood      String   @unique
  inhaleSec Int
  holdSec   Int
  exhaleSec Int
  cycles    Int
  createdAt DateTime @default(now())
}

model EmotionalPrompt {
  id        String   @id
  text      String
  category  String?
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  TRIAL
  PREMIUM
}

enum MoodType {
  VERY_BAD
  BAD
  NEUTRAL
  GOOD
  VERY_GOOD
  JOYFUL
  EXCITED
  PROUD
  GRATEFUL
  PEACEFUL
  CONTENT
  PLAYFUL
  HOPEFUL
  CURIOUS
  SAD
  DEPRESSED
  LONELY
  HURT
  DISAPPOINTED
  ANGRY
  FRUSTRATED
  ANNOYED
  ANXIOUS
  OVERWHELMED
  STRESSED
  NERVOUS
  INSECURE
  TIRED
  BORED
  NUMB
  GUILTY
  ASHAMED
}
