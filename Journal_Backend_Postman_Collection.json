{
    "info": {
        "_postman_id": "journal-backend-api",
        "name": "Journal Backend API",
        "description": "2-Step Signup: Step 1 = Google OAuth → provisionalToken. Step 2 = Phone OTP → accessToken.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Step 1 — Google Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.provisionalToken) {",
                                    "    pm.environment.set('provisionalToken', jsonData.provisionalToken);",
                                    "    console.log('Provisional token saved. Proceed to Step 2 (Verify Phone).');",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"idToken\": \"YOUR_GOOGLE_ID_TOKEN\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/google",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "google"
                            ]
                        },
                        "description": "Step 1 of 2-step signup. Verifies Google ID token and returns a short-lived provisionalToken (10 min). No full session is created yet.\n\nThe test script automatically saves the provisionalToken to the environment."
                    },
                    "response": []
                },
                {
                    "name": "Step 2 — Verify Phone (OTP)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.accessToken) {",
                                    "    pm.environment.set('accessToken', jsonData.accessToken);",
                                    "    pm.environment.set('refreshToken', jsonData.refreshToken);",
                                    "    pm.environment.unset('provisionalToken');",
                                    "    console.log('Full session created. User is now authenticated.');",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{provisionalToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"phone\": \"+1234567890\",\n    \"otp\": \"123456\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/verify-phone",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "verify-phone"
                            ]
                        },
                        "description": "Step 2 of 2-step signup.\n\nRequires: Authorization: Bearer {{provisionalToken}} (from Step 1).\n\nDev OTP: 123456\n\nOn success, returns a full accessToken + refreshToken. The test script saves them automatically and clears the provisionalToken."
                    },
                    "response": []
                },
                {
                    "name": "Refresh Token",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.accessToken) {",
                                    "    pm.environment.set('accessToken', jsonData.accessToken);",
                                    "    pm.environment.set('refreshToken', jsonData.refreshToken);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"refreshToken\": \"{{refreshToken}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/refresh",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "refresh"
                            ]
                        },
                        "description": "Get a new access token using a valid refresh token. Implements token rotation — the old refresh token is invalidated."
                    },
                    "response": []
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"sessionId\": \"SESSION_ID_HERE\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/logout",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "logout"
                            ]
                        },
                        "description": "Invalidates the current session. The sessionId can be decoded from the accessToken payload."
                    },
                    "response": []
                },
                {
                    "name": "Admin Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
